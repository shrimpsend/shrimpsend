# ShrimpSend Web — 复制为 `.env.local`（gitignored）
#
# 公开仓仅保留本 example。真实 Stripe Price / OpenPanel secret 在私有 ops 仓：
#   ops/web/.env.local  →  ./ops/scripts/sync-to-build-machine.sh  →  web/.env.local
#
# Stripe Price（NEXT_PUBLIC_* 会打进前端 bundle）
# 两套变量：沙盒与线上，由 NEXT_PUBLIC_STRIPE_BILLING 选择（sandbox | live）
NEXT_PUBLIC_STRIPE_BILLING=sandbox

# 沙盒 Stripe Price（本地 / 测试）
NEXT_PUBLIC_STRIPE_SANDBOX_PLUS_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_SANDBOX_PLUS_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_SANDBOX_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_SANDBOX_PRO_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_SANDBOX_ULTRA_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_SANDBOX_ULTRA_YEARLY=price_xxx

# 线上 Stripe Price（生产部署时填入，勿提交公开仓）
NEXT_PUBLIC_STRIPE_LIVE_PLUS_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_LIVE_PLUS_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_LIVE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_LIVE_PRO_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_LIVE_ULTRA_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_LIVE_ULTRA_YEARLY=price_xxx

# OpenPanel（secret 放 .env.local，勿提交）
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
NEXT_PUBLIC_OPENPANEL_CLIENT_SECRET=
NEXT_PUBLIC_OPENPANEL_API_URL=https://openpanel.example.com/api

NEXT_PUBLIC_OPENPANEL_INTL_CLIENT_ID=
NEXT_PUBLIC_OPENPANEL_INTL_CLIENT_SECRET=
NEXT_PUBLIC_OPENPANEL_INTL_API_URL=https://openpanel.example.com/api

# 管理员邮箱（逗号分隔，须与后端 APP_ADMIN_EMAILS 一致；NEXT_PUBLIC_ 前缀才能打进前端 bundle，修改后需重新 build）
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com
