# Spring Boot 环境变量参考（生产值放 ops 仓或服务器环境，勿提交）
# 详见 docs/SELF_HOST.md

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ultrasend
SPRING_DATASOURCE_USERNAME=ultrasend
SPRING_DATASOURCE_PASSWORD=changeme

JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me

CENTRIFUGO_HTTP_API_KEY=dev-centrifugo-http-api-key
CENTRIFUGO_TOKEN_HMAC_SECRET=dev-centrifugo-hmac-secret-change-me

# 云端 text 正文 AES-GCM 密钥（Base64，16/24/32 字节）；本地由 setup-local-config.sh 自动生成
APP_MESSAGES_ENCRYPTION_KEY_BASE64=
APP_MESSAGES_ENCRYPTION_ALLOW_DEV_FALLBACK=true
APP_MESSAGES_ENCRYPTION_MIGRATE_ON_STARTUP=false

APP_ADMIN_EMAILS=admin@example.com
# 生产环境也可在 ops application-prod*.yml 的 app.admin.emails 中配置（与 web NEXT_PUBLIC_ADMIN_EMAILS 保持一致）

SENDCLOUD_API_USER=
SENDCLOUD_API_KEY=

TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_SIGN_NAME=

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_ALIPAY_PUBLIC_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

REVENUECAT_WEBHOOK_AUTH=

HOSTED_S3_ENDPOINT=
HOSTED_S3_ACCESS_KEY_ID=
HOSTED_S3_SECRET_ACCESS_KEY=
HOSTED_S3_BUCKET=

STORAGE_S3_ENDPOINT=https://cos.ap-guangzhou.myqcloud.com
STORAGE_S3_REGION=ap-guangzhou
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_BUCKET=
STORAGE_S3_PUBLIC_HOST=
